  "methodology": {
    "tag": "Our Approach",
    "title": "Kairos means the <em style=\"color: rgba(201,168,76,0.85);\">right moment.</em>",
    "sub": "Most consultants focus on the application. We focus on the student. The application is just the expression of the work we do together.",
    "cards": [
      {
        "num": "01",
        "title": "Story First",
        "desc": "Before we open Common App, we spend sessions excavating who you actually are — your values, your experiences, your thinking patterns. The essay doesn't create the story. The story creates the essay."
      },
      {
        "num": "02",
        "title": "Strategic Precision",
        "desc": "ED, ED2, EA, RD — timing is everything. School selection, major choice, application round, essay positioning: every decision is made with your specific profile in mind. No cookie-cutter lists."
      },
      {
        "num": "03",
        "title": "Voice Preservation",
        "desc": "We never write a single word of your essay. We coach, challenge, and refine — but every sentence is yours. Admissions officers can detect a ghost-written essay. Authenticity is your greatest competitive advantage."
      },
      {
        "num": "04",
        "title": "Cultural Fluency",
        "desc": "We understand international students — whether you're at an IB school in Singapore, a boarding school in the UK, or a private school in Seoul. We've worked with students from Korea, Jordan, Ethiopia, Singapore, the US, and more. We translate your experience into a language elite universities respond to."
      }
    ]
  },
  "about": {
    "name": "Ron Kim",
    "role": "Founder, Kairos Education",
    "credentials": [
      "University of Illinois (Sociology & Criminology)"
    ],
    "tag": "About",
    "title": "Built on real results,<br /><em>not brand names.</em>",
    "blocks": [
      {
        "isP": true,
        "html": "I founded Kairos Education because I saw a gap: students who deserved elite outcomes\r\n          were getting generic strategies. Big consulting firms scale by selling templates.\r\n          I scale by <strong>knowing every student by name.</strong>"
      },
      {
        "isP": true,
        "html": "I graduated from an IB international school in Korea and went on to study Sociology and Criminology\r\n          at the University of Illinois Urbana-Champaign. I then spent years as a college consultant,\r\n          IB/AP instructor, and international school college counselor — working directly with students\r\n          from Korea, Singapore, Ethiopia, Jordan, the UK, and the US, guiding them to admissions at\r\n          Harvard, Yale, Columbia, UPenn, Dartmouth, Cornell, Duke, Johns Hopkins, and UChicago."
      },
      {
        "isP": true,
        "html": "\"The students I remember aren't the ones with the highest SAT scores.\r\n          They're the ones who found their real story — and had the courage to tell it.\""
      },
      {
        "isP": true,
        "html": "At Kairos, I work directly with every student. You will never be handed off to a junior coach.\r\n          The strategy, the essay feedback, the calls — that's me, every time."
      }
    ]
  },
