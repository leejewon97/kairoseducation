<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ metaDescription }}" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/assets/favicon-48x48.png" type="image/png" sizes="48x48" />
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:description" content="{{ ogDescription }}" />
  <meta property="og:image" content="https://kairoseducation.org/assets/og-image.png" />
  <meta property="og:url" content="https://kairoseducation.org/" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="{{ title }}" />
  <meta name="twitter:description" content="{{ ogDescription }}" />
  <meta name="twitter:image" content="https://kairoseducation.org/assets/og-image.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link id="fonts-link" href="{{ fontsHref }}" rel="stylesheet" />
  <link rel="stylesheet" href="/assets/kairos-tokens.css" />
  <link rel="stylesheet" href="/assets/kairos-shared.css" />
  <link rel="stylesheet" href="/assets/index-site.css" />
</head>
<body>
  <main class="landing-page">
    <div class="landing-inner">
      <img class="landing-logo reveal" src="/assets/img/logo.png" alt="Kairos Education" width="130" height="130" />
      <h1 class="reveal" id="landing-h1">{{{ h1 }}}</h1>
      <div class="landing-tag reveal" id="landing-tag">{{ tagline }}</div>
      <div class="lang-label reveal" id="lang-label">{{ langLabel }}</div>
      <div class="lang-row reveal" id="lang-row" role="group" aria-labelledby="lang-label">
        {% for chip in langChips %}
        <button type="button" class="lang-chip" data-lang="{{ chip.code }}" aria-pressed="false">
          <span class="flag">{{ chip.flag }}</span>{{ chip.label }}
        </button>
        {% endfor %}
      </div>
      <div class="path-label reveal" id="path-label">{{ pathLabel }}</div>
      <div class="paths reveal">
        <a href="/origin.html?lang=en" class="path-card" id="path-us">
          <span class="pc-flag" id="path-us-flag">{{ pathUs.flag }}</span>
          <div class="pc-k" id="path-us-title">{{ pathUs.title }}</div>
          <div class="pc-d" id="path-us-desc">{{ pathUs.desc }}</div>
          <div class="pc-go"><span class="path-enter">{{ enter }}</span> <span class="arrow">→</span></div>
        </a>
        <a href="/study-korea.html?lang=en" class="path-card" id="path-korea">
          <span class="pc-flag" id="path-korea-flag">{{ pathKorea.flag }}</span>
          <div class="pc-k" id="path-korea-title">{{ pathKorea.title }}</div>
          <div class="pc-d" id="path-korea-desc">{{ pathKorea.desc }}</div>
          <div class="pc-go"><span class="path-enter">{{ enter }}</span> <span class="arrow">→</span></div>
        </a>
      </div>
    </div>
  </main>

  <script type="module" src="/assets/index-locale.js"></script>
  <script type="module" src="/assets/interactions.js"></script>
</body>
</html>
