<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/assets/favicon-48x48.png" type="image/png" sizes="48x48" />
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
  <meta name="description" content="{{ metaDescription }}" />
{{{ ogTwitterTags }}}
{{{ seoLinks }}}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="/assets/origin-site.css" />
  <style>body { font-family: sans-serif; } body.i18n-loading { visibility: hidden; }</style>
</head>
<body>

  <nav>
    <a href="/" class="nav-logo" aria-label="Kairos">
      <img src="/assets/kairos_logo-web.png" alt="Kairos" class="site-logo" />
    </a>
    <ul class="nav-links">
      <li><a href="#results" id="mount-nav-results">{{ nav.results }}</a></li>
      <li><a href="#packages" id="mount-nav-packages">{{ nav.packages }}</a></li>
      <li><a href="#methodology" id="mount-nav-methodology">{{ nav.methodology }}</a></li>
      <li><a href="#about" id="mount-nav-about">{{ nav.about }}</a></li>
      <li><a href="#faq" id="mount-nav-faq">{{ nav.faq }}</a></li>
    </ul>
    <div class="nav-right">
      <div id="mount-lang-switcher" style="display:flex; align-items:center; gap:8px;"></div>
      <a href="#contact" class="nav-cta" id="mount-nav-cta">{{ nav.cta }}</a>
    </div>
  </nav>

  <section class="hero">
    <div class="hero-content">
      <div class="hero-badge" id="mount-hero-badge">{{ hero.badge }}</div>
      <h1 id="mount-hero-h1">{{{ hero.h1 }}}</h1>
      <p id="mount-hero-sub">{{ hero.sub }}</p>
      <div class="hero-actions">
        <a href="#packages" class="btn-primary" id="mount-hero-primary">{{ hero.primaryCta }}</a>
        <a href="#results" class="btn-secondary" id="mount-hero-secondary">{{ hero.secondaryCta }}</a>
      </div>
    </div>
  </section>

  <div class="stats-banner" id="mount-stats">
    {% for stat in stats %}
    <div class="stat-item">
      <span class="stat-number">{{ stat.number }}</span>
      <span class="stat-label">{{{ stat.label }}}</span>
    </div>
    {% endfor %}
  </div>

  <section class="results" id="results">
    <div class="section-tag" id="mount-results-tag">{{ results.tag }}</div>
    <h2 class="section-title" id="mount-results-title">{{{ results.title }}}</h2>
    <p class="section-sub" id="mount-results-sub">{{ results.sub }}</p>
    <div id="mount-results-tiers">
    {% for tierGroup in results.tiers %}
    <p class="tier-label">{{ tierGroup.label }}</p>
    <div class="results-grid" style="margin-bottom: 40px;">
      {% for uni in tierGroup.universities %}
      {% if uni.nicheUrl %}
      <a class="uni-card" href="{{ uni.nicheUrl }}" target="_blank" rel="noopener">
        <div class="uni-tier">
          {% if uni.intl %}
          <div class="tier-dot" style="background:#6B7280"></div>
          {% else %}
          <div class="tier-dot tier-{{ uni.tier }}"></div>
          {% endif %}
        </div>
        <div class="uni-name">{{ uni.name }}</div>
        <div class="uni-detail">{{ uni.detail }}</div>
      </a>
      {% else %}
      <div class="uni-card">
        <div class="uni-tier">
          {% if uni.intl %}
          <div class="tier-dot" style="background:#6B7280"></div>
          {% else %}
          <div class="tier-dot tier-{{ uni.tier }}"></div>
          {% endif %}
        </div>
        <div class="uni-name">{{ uni.name }}</div>
        <div class="uni-detail">{{ uni.detail }}</div>
      </div>
      {% endif %}
      {% endfor %}
    </div>
    {% endfor %}
    </div>
    <p style="font-size: 13px; color: var(--text-muted);" id="mount-results-legend">{{ results.legend }}</p>
  </section>

  <section class="packages-section" id="packages">
    <div class="section-tag" id="mount-services-tag">{{ services.tag }}</div>
    <h2 class="section-title" id="mount-services-title">{{{ services.title }}}</h2>
    <p class="section-sub" id="mount-services-sub">{{ services.sub }}</p>
    <div class="packages-row" id="mount-packages">
      {% for pkg in services.packages %}
      <div class="pkg{% if pkg.featured %} featured{% endif %}">
        <div class="pkg-tier">
          <div>
            <div class="pkg-roman">{{ pkg.roman }}</div>
            <div class="pkg-name">{{ pkg.name }}</div>
            <div class="pkg-subtitle">{{ pkg.schools }}</div>
            {% if pkg.badge %}<div class="pkg-badge">{{ pkg.badge }}</div>{% endif %}
          </div>
        </div>
        <div class="pkg-features-col">
          <ul class="pkg-feat-list">
            {% for feature in pkg.features %}
            <li>{{ feature }}</li>
            {% endfor %}
          </ul>
        </div>
        <div class="pkg-price-col">
          <div class="pkg-usd">{{ pkg.price }}</div>
          {% if pkg.max %}
          <div class="pkg-krw">{{ pkg.max }}</div>
          {% else %}
          <div class="pkg-krw pkg-krw--placeholder" aria-hidden="true">&#8203;</div>
          {% endif %}
          <a href="#contact" class="pkg-cta">{{ services.packageCta }}</a>
        </div>
      </div>
      {% endfor %}
    </div>
  </section>

  <section class="origin-alacarte-section" id="alacarte">
    <h2 class="section-title" id="mount-alc-title">{{ services.alacarteHeading }}</h2>
    <p class="section-sub" id="mount-alc-sub">{{ services.alacarteSub }}</p>
    <div class="alacarte-grid" id="mount-alacarte-grid">
      {% for row in services.alacarte %}
      <div class="alacarte-card">
        <div>
          <div class="alacarte-name">{{ row.service }}</div>
        </div>
        <div class="alacarte-price">
          <div class="alacarte-usd">{{ row.usd }}</div>
          {% if row.krw %}
          <div class="alacarte-krw">{{ row.krw }}</div>
          {% else %}
          <div class="alacarte-krw alacarte-krw--placeholder" aria-hidden="true">&#8203;</div>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
    <p style="font-size:13px;color:var(--text-muted);margin-top:16px;text-align:center;" id="mount-alacarte-note">{{ services.alacarteNote }}</p>
    <p style="font-size:13px;color:var(--text-muted);margin-top:28px;text-align:center;" id="mount-services-disclaimer">{{ services.disclaimer }}</p>
  </section>

  <section class="method" id="methodology">
    <div class="section-tag" style="color: var(--gold);" id="mount-method-tag">{{ methodology.tag }}</div>
    <h2 class="section-title" id="mount-method-title">{{{ methodology.title }}}</h2>
    <p class="section-sub" id="mount-method-sub">{{ methodology.sub }}</p>
    <div class="method-grid" id="mount-method-cards">
      {% for card in methodology.cards %}
      <div class="method-card">
        <div class="method-num">{{ card.num }}</div>
        <div class="method-title">{{ card.title }}</div>
        <div class="method-desc">{{ card.desc }}</div>
      </div>
      {% endfor %}
    </div>
  </section>

  <section id="about">
    <div class="about-inner">
      <div class="about-image-block">
        <div class="about-initial">RK</div>
        <div class="about-name-block">
          <div class="about-divider"></div>
          <div class="about-name" id="mount-about-name">{{ about.name }}</div>
          <div class="about-title" id="mount-about-role">{{ about.role }}</div>
        </div>
        <ul class="credentials" id="mount-credentials">
          {% for cred in about.credentials %}
          <li>{{ cred }}</li>
          {% endfor %}
        </ul>
      </div>
      <div class="about-content">
        <div class="section-tag" id="mount-about-tag">{{ about.tag }}</div>
        <h2 class="section-title" id="mount-about-title">{{{ about.title }}}</h2>
        <div id="mount-about-blocks">
        {% for block in about.blocks %}
        {% if block.isP %}
        <p>{{{ block.html }}}</p>
        {% else %}
        <div class="about-quote">
          <p>{{ block.text }}</p>
        </div>
        {% endif %}
        {% endfor %}
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section" id="faq">
    <div class="section-tag" id="mount-faq-tag">{{ faq.tag }}</div>
    <h2 class="section-title" id="mount-faq-title">{{{ faq.title }}}</h2>
    <p class="section-sub" id="mount-faq-sub">{{ faq.sub }}</p>
    <div class="faq-list" id="mount-faq-list">
      {% for item in faq.items %}
      <div class="faq-item">
        <button class="faq-q" type="button">
          {{ item.q }}
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-a">{{{ item.a }}}</div>
      </div>
      {% endfor %}
    </div>
  </section>

  <section class="contact" id="contact">
    <div class="contact-inner">
      <div class="contact-info">
        <div class="section-tag" id="mount-contact-tag">{{ contact.tag }}</div>
        <h2 id="mount-contact-title">{{{ contact.title }}}</h2>
        <p id="mount-contact-sub">{{ contact.sub }}</p>
        <div class="contact-details">
          <div class="contact-item">
            <div class="contact-icon">📧</div>
            <div class="contact-text">
              <strong id="mount-email-label">{{ contact.emailLabel }}</strong>
              <span>ronkim@kairos-education.org</span>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon">💬</div>
            <div class="contact-text">
              <strong id="mount-kakao-label">{{ contact.kakaoLabel }}</strong>
              <span id="mount-kakao-html">{{{ contact.kakaoLinkHtml }}}</span>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon">📍</div>
            <div class="contact-text">
              <strong id="mount-location-label">{{ contact.locationLabel }}</strong>
              <span id="mount-location">{{ contact.location }}</span>
            </div>
          </div>
        </div>
      </div>
      <div id="mount-forms">
        {{{ netlifyFormsHtml }}}
      </div>
    </div>
  </section>

  <footer>
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/" class="nav-logo" aria-label="Kairos">
          <img src="/assets/kairos_logo-web.png" alt="Kairos" class="site-logo" />
        </a>
        <p id="mount-footer-tagline">{{ footer.tagline }}</p>
      </div>
      <div class="footer-links">
        <h4 id="mount-footer-nav-heading">{{ footer.navigateHeading }}</h4>
        <ul id="mount-footer-nav">
          {% for item in footer.nav %}
          <li><a href="{{ item.href }}">{{ item.text }}</a></li>
          {% endfor %}
        </ul>
      </div>
      <div class="footer-links">
        <h4 id="mount-footer-admits-heading">{{ footer.admitsHeading }}</h4>
        <ul id="mount-footer-admits">
          {% for item in footer.admits %}
          <li><a href="{{ item.href }}">{{ item.text }}</a></li>
          {% endfor %}
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p id="mount-footer-copyright">{{ footer.copyright }}</p>
      <p id="mount-footer-meta">{{ footer.meta }}</p>
    </div>
  </footer>

  <script type="module" src="/assets/origin-locale.js"></script>
</body>
</html>
