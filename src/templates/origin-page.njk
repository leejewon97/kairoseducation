<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/assets/favicon-48x48.png" type="image/png" sizes="48x48" />
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
  <meta name="description" content="{{ metaDescription }}" />
{{{ ogTwitterTags }}}
{{{ seoLinks }}}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="/assets/kairos-tokens.css" />
  <link rel="stylesheet" href="/assets/kairos-shared.css" />
  <link rel="stylesheet" href="/assets/origin-site.css" />
  <style>body.i18n-loading { visibility: hidden; }</style>
</head>
<body class="in-page">

  <div class="scarcity" id="mount-scarcity">{{{ scarcity }}}</div>

  <header class="header" id="header">
    <div class="nav">
      <a href="/" class="brand" aria-label="Kairos">
        <img src="/assets/img/logo.png" alt="Kairos Education" width="38" height="38" />
        <span class="wm">KAIROS</span>
      </a>
      <div class="nav-center">
        <nav class="nav-links-group active">
          <a class="nlink" href="#results" id="mount-nav-results">{{ nav.results }}</a>
          <a class="nlink" href="#us-worries" id="mount-nav-why">{{ nav.why }}</a>
          <a class="nlink" href="#about" id="mount-nav-about">{{ nav.about }}</a>
          <a class="nlink" href="#us-process" id="mount-nav-process">{{ nav.process }}</a>
          <a class="nlink" href="#packages" id="mount-nav-packages">{{ nav.packages }}</a>
          <a class="nlink" href="#faq" id="mount-nav-faq">{{ nav.faq }}</a>
        </nav>
      </div>
      <div class="nav-right">
        <div class="lang" id="lang">
          <button type="button" class="lang-btn" aria-haspopup="true" aria-expanded="false" aria-label="Select language">
            <span class="flag" aria-hidden="true">🇺🇸</span>
            <span id="langCur">English</span>
            <span class="car" aria-hidden="true"></span>
          </button>
          <div class="lang-menu" role="menu" id="mount-lang-switcher"></div>
        </div>
        <a class="btn btn-navy" href="#contact" data-view="contact" data-nav-cta>{{ nav.cta }}</a>
        <button type="button" class="burger" id="burger" aria-label="{{ nav.menuOpen }}">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </header>

  <div class="mobile-menu" id="mobileMenu">
    <button type="button" class="mm-close" aria-label="{{ nav.menuClose }}">&times;</button>
    <div id="mount-mobile-links"></div>
  </div>

  <div class="view view-us active" id="view-us">

  <div class="hero">
    <svg class="hero-arc" viewBox="0 0 600 600" aria-hidden="true">
      <path d="M520 80 A 300 300 0 1 0 520 520" />
      <path d="M120 300 A 240 240 0 0 1 540 150" style="opacity:.35" />
      <g class="hero-star" transform="translate(516,84)">
        <path d="M0,-22 L5,-5 L22,0 L5,5 L0,22 L-5,5 L-22,0 L-5,-5 Z" fill="#C9A24C" />
      </g>
    </svg>
    <div class="wrap hero-inner">
      <span class="eyebrow reveal" id="mount-hero-badge">{{ hero.badge }}</span>
      <h1 class="reveal" id="mount-hero-h1" style="transition-delay:.1s">{{{ hero.h1 }}}</h1>
      <p class="lead reveal" id="mount-hero-lead" style="transition-delay:.2s">{{ hero.lead }}</p>
      <div class="hero-cta reveal" id="mount-hero-cta" style="transition-delay:.3s">
        <a class="btn btn-navy" href="#contact" data-view="contact" id="mount-hero-primary">{{{ hero.primaryCta }}}</a>
        <a class="btn btn-ghost" href="#results" id="mount-hero-secondary">{{ hero.secondaryCta }}</a>
      </div>
      <div class="authority reveal" style="transition-delay:.4s">
        <div class="al" id="mount-hero-authority">{{ hero.authority }}</div>
        <div class="marquee" id="mount-hero-marquee" role="img" aria-label="Harvard, Yale, Columbia, Penn, Dartmouth, Cornell, Brown, Chicago, Duke">
          <div class="marquee-track">
            {% for school in hero.marquee %}
            <span class="sep">◆</span><span class="ms">{{ school }}</span>
            {% endfor %}
            <span class="marquee-dup" aria-hidden="true">
              {% for school in hero.marquee %}
              <span class="sep">◆</span><span class="ms">{{ school }}</span>
              {% endfor %}
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <section class="sec" id="results">
    <div class="wrap">
      <div class="results-top">
        <div class="sec-head reveal" style="margin-bottom:0">
          <span class="eyebrow" id="mount-results-tag">{{ results.tag }}</span>
          <h2 id="mount-results-title">{{{ results.title }}}</h2>
          <p class="lead" id="mount-results-sub">{{ results.sub }}</p>
        </div>
        <div class="admit-showcase reveal" id="admitShowcase" aria-label="Recent Kairos admits"></div>
      </div>
      <div id="mount-results-tiers"></div>
      <p class="results-note reveal" id="mount-results-note">{{ results.legend }}</p>
    </div>
  </section>

  <section class="sec cream" id="us-worries">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow" id="mount-worries-tag">{{ worries.tag }}</span>
        <h2 id="mount-worries-title">{{{ worries.title }}}</h2>
        <p class="lead" id="mount-worries-lead">{{ worries.lead }}</p>
      </div>
      <div class="worries-grid" id="mount-worries-grid">
        {% for item in worries.items %}
        <div class="worry reveal">
          <div class="wic">✓</div>
          <div>
            <h3>{{ item.title }}</h3>
            <p>{{ item.desc }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
      <div class="worries-foot reveal" id="mount-worries-foot">{{ worries.foot }}</div>
    </div>
  </section>

  <section class="band" id="us-proof">
    <div class="wrap">
      <div class="band-head reveal">
        <span class="eyebrow light center" id="mount-proof-eyebrow">{{ proof.eyebrow }}</span>
        <h2 id="mount-proof-title">{{ proof.title }}</h2>
        <p id="mount-proof-sub">{{ proof.sub }}</p>
      </div>
      <div class="stats reveal" id="mount-proof-stats">
        {% for stat in proof.stats %}
        <div class="stat">
          <div class="sk">{{ stat.value }}</div>
          <div class="sl">{{ stat.label }}</div>
        </div>
        {% endfor %}
      </div>
      <div class="band-note" id="mount-proof-note">{{ proof.note }}</div>
    </div>
  </section>

  <section class="sec cream" id="about">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow" id="mount-about-tag">{{ about.tag }}</span>
        <h2 id="mount-about-title">{{{ about.title }}}</h2>
      </div>
      <div class="about-wrap">
        <div class="headshot reveal">
          <div class="frame">
            <img src="/assets/img/ron-kim.jpg" alt="Ron Kim, Founder of Kairos Education" width="320" height="400" loading="lazy" />
          </div>
          <div class="who">
            <div class="nm" id="mount-about-name">{{ about.name }}</div>
            <div class="rl" id="mount-about-role">{{ about.role }}</div>
          </div>
        </div>
        <div class="about-text reveal" id="mount-about-blocks" style="transition-delay:.1s">
          {% for p in about.paragraphs %}
          <p>{{ p }}</p>
          {% endfor %}
          <div class="about-quote">
            <div class="q">{{ about.quote.text }}</div>
            <div class="by">{{ about.quote.by }}</div>
          </div>
          <p class="about-reassure">{{ about.reassure }}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="sec" id="us-process">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow" id="mount-process-tag">{{ process.tag }}</span>
        <h2 id="mount-process-title">{{{ process.title }}}</h2>
        <p class="lead" id="mount-process-lead">{{ process.lead }}</p>
      </div>
      <div class="process" id="mount-process-steps">
        {% for step in process.steps %}
        <div class="step reveal">
          <div class="step-n"></div>
          <div>
            <h3>{{ step.title }}</h3>
            <p>{{ step.desc }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="sec cream" id="us-testimonials">
    <div class="wrap">
      <div class="sec-head center reveal">
        <span class="eyebrow center" id="mount-testimonials-eyebrow">{{ testimonials.eyebrow }}</span>
        <h2 id="mount-testimonials-title">{{{ testimonials.title }}}</h2>
      </div>
      <div class="testi-grid" id="mount-testimonials">
        {% for item in testimonials.items %}
        <div class="testi reveal">
          <div class="stars-row">★★★★★</div>
          <div class="qt">{{ item.quote }}</div>
          <div class="who">
            <div class="av">{{ item.by }}</div>
            <div class="at">{{ item.by }}</div>
          </div>
        </div>
        {% endfor %}
      </div>
      <div class="testi-note" id="mount-testimonials-note">{{ testimonials.note }}</div>
    </div>
  </section>

  <section class="sec" id="packages">
    <div class="wrap">
      <div class="sec-head center reveal">
        <span class="eyebrow center" id="mount-packages-tag">{{ services.tag }}</span>
        <h2 id="mount-packages-title">{{{ services.title }}}</h2>
        <p class="lead" style="margin:0 auto" id="mount-packages-sub">{{ services.sub }}</p>
      </div>
      <div class="pkg-grid" id="mount-packages-grid">
        {% for pkg in services.packages %}
        <div class="pkg{% if pkg.featured %} feature{% endif %} reveal">
          {% if pkg.badge %}<span class="pkg-tag">{{ pkg.badge }}</span>{% endif %}
          <span class="pkg-num">{{ pkg.roman }}</span>
          <div class="pkg-name">{{ pkg.name }}</div>
          <div class="pkg-best">{{ pkg.best }}</div>
          <div class="pkg-desc">{{ pkg.desc }}</div>
          <ul class="pkg-list">
            {% for feature in pkg.features %}
            <li>{{ feature }}</li>
            {% endfor %}
          </ul>
          <div class="pkg-foot">
            <div class="pkg-price">{{ pkg.price }}</div>
            {% if pkg.max %}<div class="pkg-krw">{{ pkg.max }}</div>{% endif %}
            <div class="pkg-meta">{{ pkg.meta }}</div>
            <a class="{{ pkg.btnClass }}" href="#contact" data-view="contact">{{{ pkg.btnHtml }}}</a>
          </div>
        </div>
        {% endfor %}
      </div>
      <div class="ala reveal" id="mount-alacarte">
        <h3 id="mount-alc-title">{{ services.alacarteHeading }}</h3>
        <div class="ala-sub" id="mount-alc-sub">{{ services.alacarteSub }}</div>
        <div class="ala-list">
          {% for row in services.alacarte %}
          <div class="ala-row">
            <span class="nm">{{ row.service }}</span>
            <span class="ldr"></span>
            <span class="pr">{{ row.usd }}</span>
            {% if row.krw %}<span class="pr krw">{{ row.krw }}</span>{% endif %}
          </div>
          {% endfor %}
        </div>
        <div class="ala-foot" id="mount-alacarte-foot">{{ services.alacarteNote }}</div>
      </div>
      <p class="price-note reveal" id="mount-packages-note">{{ services.priceNote }}</p>
    </div>
  </section>

  <section class="sec cream" id="faq">
    <div class="wrap">
      <div class="sec-head center reveal">
        <span class="eyebrow center" id="mount-faq-tag">{{ faq.tag }}</span>
        <h2 id="mount-faq-title">{{{ faq.title }}}</h2>
      </div>
      <div class="faq-wrap reveal" id="mount-faq-list">
        {% for item in faq.items %}
        <div class="faq-item">
          <button class="faq-q" type="button">
            <span>{{ item.q }}</span>
            <span class="faq-ic"></span>
          </button>
          <div class="faq-a"><p>{{{ item.a }}}</p></div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="video-cta" id="video-cta">
    <img class="video-cta-bg" src="{{ videoCta.poster }}" alt="" width="1920" height="1080" loading="lazy" />
    <div class="video-cta-inner reveal">
      <h2 id="mount-video-cta-title">{{ videoCta.title }}</h2>
      <p class="video-cta-sub" id="mount-video-cta-sub">{{ videoCta.sub }}</p>
      <a class="btn btn-light" href="#contact" data-view="contact" id="mount-video-cta-btn">{{ videoCta.cta }}</a>
    </div>
  </section>

  </div>

  <div class="view view-contact" id="view-contact">
  <section class="sec" id="contact">
    <div class="wrap">
      <div class="sec-head center reveal" id="mount-contact-head" style="margin:0 auto 56px">
        <span class="eyebrow center" id="mount-contact-tag">{{ contact.tag }}</span>
        <h2 id="mount-contact-title">{{{ contact.title }}}</h2>
        <p class="lead" style="margin:0 auto" id="mount-contact-sub">{{ contact.sub }}</p>
      </div>
      <div class="contact-grid">
        <div class="contact-expect reveal">
          <h3 class="expect-title" id="mount-expect-title">{{ contact.expect.title }}</h3>
          <div class="expect-steps" id="mount-expect-steps">
            {% for step in contact.expect.steps %}
            <div class="expect-step">
              <span class="expect-n"></span>
              <div>
                <h4>{{ step.title }}</h4>
                <p>{{ step.desc }}</p>
              </div>
            </div>
            {% endfor %}
          </div>
          <div class="contact-methods">
            <div class="contact-detail">
              <div class="ic">✉</div>
              <div>
                <div class="lb" id="mount-email-label">{{ contact.emailLabel }}</div>
                <div class="vl">ronkim@kairos-education.org</div>
              </div>
            </div>
            <div class="contact-detail">
              <div class="ic">📍</div>
              <div>
                <div class="lb" id="mount-location-label">{{ contact.locationLabel }}</div>
                <div class="vl" id="mount-location">{{ contact.location }}</div>
              </div>
            </div>
          </div>
          <div class="contact-chat" id="mount-contact-chat"></div>
        </div>
        <div id="mount-forms">
          {{{ netlifyFormsHtml }}}
        </div>
      </div>
    </div>
  </section>
  </div>

  <footer class="footer" id="footer">
    <div class="wrap">
      <div class="footer-top">
        <div class="footer-brand">
          <div class="fwm"><span class="star">✦</span> KAIROS EDUCATION</div>
          <div class="ft-tag" id="mount-footer-tagline">{{ footer.tagline }}</div>
        </div>
        <div class="footer-col">
          <h4 id="mount-footer-col1-heading">{{ footer.col1Heading }}</h4>
          <div id="mount-footer-col1">
            {% for item in footer.col1 %}
            <a href="{{ item.href }}">{{ item.text }}</a>
            {% endfor %}
          </div>
        </div>
        <div class="footer-col">
          <h4 id="mount-footer-col2-heading">{{ footer.col2Heading }}</h4>
          <div id="mount-footer-col2">
            {% for item in footer.col2 %}
            <a href="{{ item.href }}">{{ item.text }}</a>
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="footer-disc" id="mount-footer-disc">{{ footer.disc }}</div>
      <div class="footer-bot">
        <div id="mount-footer-copyright">{{ footer.copyright }}</div>
        <div id="mount-footer-meta">{{{ footer.meta }}}</div>
      </div>
    </div>
  </footer>

  <div class="chat-fab" id="chatFab" aria-label="Chat with Kairos">
    <a class="cf cf-whatsapp" href="https://wa.me/0000000000" target="_blank" rel="noopener" aria-label="Chat on WhatsApp">
      <svg viewBox="0 0 32 32" width="26" height="26" fill="currentColor" aria-hidden="true">
        <path d="M16.04 4C9.96 4 5 8.94 5 15.02c0 2.13.6 4.1 1.64 5.8L5 28l7.36-1.6c1.13.62 2.4.95 3.68.95h.01C22.12 27.35 27 22.4 27 16.33 27 10.25 22.12 4 16.04 4zm0 21.35h-.01c-1.16 0-2.3-.31-3.3-.9l-.24-.14-3.9.85.83-3.8-.16-.25a8.2 8.2 0 0 1-1.26-4.36c0-4.54 3.7-8.24 8.25-8.24 2.2 0 4.27.86 5.83 2.42a8.16 8.16 0 0 1 2.42 5.83c0 4.54-3.7 8.24-8.25 8.24zm4.52-6.17c-.25-.12-1.47-.72-1.69-.8-.23-.08-.39-.12-.56.13-.16.25-.64.8-.79.97-.14.16-.29.18-.54.06-.25-.12-1.05-.39-2-1.23-.74-.66-1.24-1.48-1.38-1.73-.14-.25-.02-.39.11-.51.11-.11.25-.29.37-.43.12-.14.16-.25.25-.41.08-.16.04-.31-.02-.43-.06-.12-.56-1.35-.77-1.85-.2-.48-.41-.42-.56-.43h-.48c-.16 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.16 1.75 2.67 4.25 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28z" />
      </svg>
    </a>
    <a class="cf cf-kakao" href="http://pf.kakao.com/_uWJKX" target="_blank" rel="noopener" aria-label="Chat on KakaoTalk">
      <svg viewBox="0 0 32 32" width="25" height="25" fill="currentColor" aria-hidden="true">
        <path d="M16 6C9.92 6 5 9.9 5 14.7c0 3.08 2.03 5.78 5.08 7.3-.22.8-.8 2.9-.92 3.35-.14.56.2.55.43.4.18-.12 2.85-1.94 4-2.72.77.11 1.57.17 2.41.17 6.08 0 11-3.9 11-8.7C27 9.9 22.08 6 16 6z" />
      </svg>
    </a>
  </div>

  <div class="sticky" id="sticky">
    <div class="sticky-in">
      <div class="sticky-msg" id="mount-sticky-msg"></div>
      <div class="sticky-btns">
        <a class="btn btn-light sticky-cta-m" href="#contact" data-view="contact" id="mount-sticky-get-started">{{ sticky.getStarted }}</a>
        <a class="btn btn-light sticky-book" href="#contact" data-view="contact" id="mount-sticky-book">{{ sticky.bookFree }}</a>
        <a class="btn btn-kakao sticky-book" href="http://pf.kakao.com/_uWJKX" target="_blank" rel="noopener" id="mount-sticky-kakao">{{{ sticky.kakao }}}</a>
        <a class="btn btn-whatsapp" href="https://wa.me/0000000000" target="_blank" rel="noopener" id="mount-sticky-whatsapp" aria-label="WhatsApp"><svg class="btn-ic" viewBox="0 0 32 32" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M16.04 4C9.96 4 5 8.94 5 15.02c0 2.13.6 4.1 1.64 5.8L5 28l7.36-1.6c1.13.62 2.4.95 3.68.95h.01C22.12 27.35 27 22.4 27 16.33 27 10.25 22.12 4 16.04 4zm0 21.35h-.01c-1.16 0-2.3-.31-3.3-.9l-.24-.14-3.9.85.83-3.8-.16-.25a8.2 8.2 0 0 1-1.26-4.36c0-4.54 3.7-8.24 8.25-8.24 2.2 0 4.27.86 5.83 2.42a8.16 8.16 0 0 1 2.42 5.83c0 4.54-3.7 8.24-8.25 8.24zm4.52-6.17c-.25-.12-1.47-.72-1.69-.8-.23-.08-.39-.12-.56.13-.16.25-.64.8-.79.97-.14.16-.29.18-.54.06-.25-.12-1.05-.39-2-1.23-.74-.66-1.24-1.48-1.38-1.73-.14-.25-.02-.39.11-.51.11-.11.25-.29.37-.43.12-.14.16-.25.25-.41.08-.16.04-.31-.02-.43-.06-.12-.56-1.35-.77-1.85-.2-.48-.41-.42-.56-.43h-.48c-.16 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.16 1.75 2.67 4.25 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28z"/></svg> {{ sticky.whatsapp }}</a>
      </div>
    </div>
  </div>

  <script type="module" src="/assets/interactions.js"></script>
  <script type="module" src="/assets/origin-locale.js"></script>
</body>
</html>
