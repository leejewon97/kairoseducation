<!DOCTYPE html>
<html lang="en">
{{{ @include includes/site-head.njk }}}
<body class="in-page">

  <div class="scarcity" id="mount-scarcity">{{{ scarcity }}}</div>

  <header class="header" id="header">
    <div class="nav">
      <a href="/" class="brand" aria-label="Kairos">
        <img src="/assets/img/logo.png" alt="Kairos Education" width="38" height="38" />
        <span class="wm">KAIROS</span>
      </a>
      <div class="nav-center">
        <nav class="nav-links-group active">
          <a class="nlink" href="#why-korea" id="mount-nav-why-korea">{{ nav.whyKorea }}</a>
          <a class="nlink" href="#pathways" id="mount-nav-pathways">{{ nav.pathways }}</a>
          <a class="nlink" href="#packages" id="mount-nav-packages">{{ nav.packages }}</a>
          <a class="nlink" href="#faq" id="mount-nav-faq">{{ nav.faq }}</a>
        </nav>
      </div>
      <div class="nav-right">
        <div class="lang" id="lang">
          <button type="button" class="lang-btn" aria-haspopup="true" aria-expanded="false" aria-label="Select language">
            <span class="flag" aria-hidden="true">🇺🇸</span>
            <span id="langCur">English</span>
            <span class="car" aria-hidden="true"></span>
          </button>
          <div class="lang-menu" role="menu" id="mount-lang-switcher"></div>
        </div>
        <a class="btn btn-navy" href="{{ contactPath }}" data-nav-cta>{{ nav.cta }}</a>
        <button type="button" class="burger" id="burger" aria-label="{{ nav.menuOpen }}">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </header>

{{{ @include includes/mobile-menu.njk }}}

  <div class="hero">
    <svg class="hero-arc" viewBox="0 0 600 600" aria-hidden="true">
      <path d="M520 80 A 300 300 0 1 0 520 520" />
      <path d="M120 300 A 240 240 0 0 1 540 150" style="opacity:.35" />
      <g class="hero-star" transform="translate(516,84)">
        <path d="M0,-22 L5,-5 L22,0 L5,5 L0,22 L-5,5 L-22,0 L-5,-5 Z" fill="#C9A24C" />
      </g>
    </svg>
    <div class="wrap hero-inner">
      <span class="eyebrow reveal" id="mount-hero-badge">{{ hero.badge }}</span>
      <h1 class="reveal" id="mount-hero-h1" style="transition-delay:.1s">{{{ hero.h1 }}}</h1>
      <p class="lead reveal" id="mount-hero-lead" style="transition-delay:.2s">{{ hero.lead }}</p>
      <div class="hero-cta reveal" id="mount-hero-cta" style="transition-delay:.3s">
        <a class="btn btn-navy" href="{{ contactPath }}" id="mount-hero-primary">{{{ hero.primaryCta }}}</a>
        <a class="btn btn-ghost" href="#pathways" id="mount-hero-secondary">{{ hero.secondaryCta }}</a>
      </div>
      <div class="authority reveal" style="transition-delay:.4s">
        <div class="al" id="mount-hero-authority">{{ hero.authority }}</div>
        <div class="marquee" id="mount-hero-marquee" role="img" aria-label="SNU, Korea University, Yonsei, KAIST, POSTECH, Ewha">
          <div class="marquee-track">
            {% for school in hero.marquee %}
            <span class="sep">◆</span><span class="ms">{{ school }}</span>
            {% endfor %}
            <span class="marquee-dup" aria-hidden="true">
              {% for school in hero.marquee %}
              <span class="sep">◆</span><span class="ms">{{ school }}</span>
              {% endfor %}
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <section class="sec cream" id="kr-worries">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow" id="mount-worries-tag">{{ worries.tag }}</span>
        <h2 id="mount-worries-title">{{{ worries.title }}}</h2>
        <p class="lead" id="mount-worries-lead">{{ worries.lead }}</p>
      </div>
      <div class="worries-grid" id="mount-worries-grid">
        {% for item in worries.items %}
        <div class="worry reveal">
          <div class="wic">✓</div>
          <div>
            <h3>{{ item.title }}</h3>
            <p>{{ item.desc }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
      <div class="worries-foot reveal" id="mount-worries-foot">{{ worries.foot }}</div>
    </div>
  </section>

  <section class="sec" id="why-korea">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow" id="mount-why-tag">{{ why.tag }}</span>
        <h2 id="mount-why-title">{{{ why.title }}}</h2>
        <p class="lead" id="mount-why-sub">{{ why.sub }}</p>
      </div>
      <div class="process" id="mount-why-grid">
        {% for card in why.cards %}
        <div class="step reveal">
          <div class="step-n" style="font-size:1.1rem">{{ card.icon }}</div>
          <div>
            <h3>{{ card.title }}</h3>
            <p>{{ card.desc }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="band" id="kr-proof">
    <div class="wrap">
      <div class="band-head reveal">
        <span class="eyebrow light center" id="mount-proof-eyebrow">{{ proof.eyebrow }}</span>
        <h2 id="mount-proof-title">{{ proof.title }}</h2>
        <p id="mount-proof-sub">{{ proof.sub }}</p>
      </div>
      <div class="stats reveal" id="mount-proof-stats">
        {% for stat in proof.stats %}
        <div class="stat">
          <div class="sk">{{ stat.value }}</div>
          <div class="sl">{{ stat.label }}</div>
        </div>
        {% endfor %}
      </div>
      <div class="band-note" id="mount-proof-note">{{ proof.note }}</div>
    </div>
  </section>

  <section class="sec" id="pathways">
    <div class="wrap">
      <div class="sec-head center reveal">
        <span class="eyebrow center" id="mount-pathways-tag">{{ pathways.tag }}</span>
        <h2 id="mount-pathways-title">{{{ pathways.title }}}</h2>
        <p class="lead" style="margin:0 auto" id="mount-pathways-sub">{{ pathways.sub }}</p>
      </div>
      <div class="pkg-grid pkg-grid--3" id="mount-pathway-grid">
        {% for p in pathways.items %}
        <div class="pkg{% if p.featured %} feature{% endif %} reveal">
          <span class="pkg-num">{{ p.num }}</span>
          <div class="pkg-name">{{ p.name }}</div>
          <div class="pkg-best">{{ p.best }}</div>
          <div class="pkg-desc">{{ p.desc }}</div>
          <ul class="pkg-list">
            {% for d in p.details %}
            <li>{{ d }}</li>
            {% endfor %}
          </ul>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="sec cream" id="universities">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow" id="mount-uni-tag">{{ universities.tag }}</span>
        <h2 id="mount-uni-title">{{{ universities.title }}}</h2>
        <p class="lead" id="mount-uni-sub">{{ universities.sub }}</p>
      </div>
      <div id="mount-uni-groups">
        {% for group in universities.groups %}
        <div class="uni-group reveal">
          <p class="uni-group-label">{{ group.label }}</p>
          <div class="uni-grid">
            {% for u in group.universities %}
            <div class="uni-card">
              <div class="uni-flag">{{ u.flag }}</div>
              <div class="uni-rank">{{ u.rank }}</div>
              <div class="uni-name">{{ u.name }}</div>
              <div class="uni-detail">{{ u.detail }}</div>
            </div>
            {% endfor %}
          </div>
        </div>
        {% endfor %}
      </div>
      <p class="uni-footnote reveal" id="mount-uni-footnote">{{ universities.footnote }}</p>
    </div>
  </section>

  <section class="sec" id="packages">
    <div class="wrap">
      <div class="sec-head center reveal">
        <span class="eyebrow center" id="mount-packages-tag">{{ packages.tag }}</span>
        <h2 id="mount-packages-title">{{{ packages.title }}}</h2>
        <p class="lead" style="margin:0 auto" id="mount-packages-sub">{{ packages.sub }}</p>
      </div>
      <div class="pkg-grid pkg-grid--3" id="mount-packages-grid">
        {% for pkg in packages.items %}
        <div class="pkg{% if pkg.featured %} feature{% endif %} reveal">
          {% if pkg.badge %}<span class="pkg-tag">{{ pkg.badge }}</span>{% endif %}
          <span class="pkg-num">{{ pkg.roman }}</span>
          <div class="pkg-name">{{ pkg.name }}</div>
          <div class="pkg-best">{{ pkg.best }}</div>
          <div class="pkg-desc">{{ pkg.desc }}</div>
          <ul class="pkg-list">
            {% for feature in pkg.features %}
            <li>{{ feature }}</li>
            {% endfor %}
          </ul>
          <div class="pkg-foot">
            <div class="pkg-price">{{ pkg.price }}</div>
            {% if pkg.max %}<div class="pkg-krw">{{ pkg.max }}</div>{% endif %}
            <div class="pkg-meta">{{ pkg.meta }}</div>
            <a class="{{ pkg.btnClass }}" href="{{ contactPath }}">{{{ pkg.btnHtml }}}</a>
          </div>
        </div>
        {% endfor %}
      </div>
      <div class="ala reveal" id="mount-terms">
        <div class="ala-list ala-list--terms">
          <div>
            <h3 style="font-size:1.25rem;margin-bottom:14px" id="mount-terms-payment-title">{{ packages.terms.payment.title }}</h3>
            <ul class="pkg-list" id="mount-terms-payment">
              {% for item in packages.terms.payment.items %}
              <li>{{ item }}</li>
              {% endfor %}
            </ul>
          </div>
          <div>
            <h3 style="font-size:1.25rem;margin-bottom:14px" id="mount-terms-promise-title">{{ packages.terms.promise.title }}</h3>
            <ul class="pkg-list" id="mount-terms-promise">
              {% for item in packages.terms.promise.items %}
              <li>{{ item }}</li>
              {% endfor %}
            </ul>
          </div>
        </div>
      </div>
      <p class="price-note reveal" id="mount-packages-note">{{ packages.priceNote }}</p>
    </div>
  </section>

  <section class="sec" id="faq">
    <div class="wrap">
      <div class="sec-head center reveal">
        <span class="eyebrow center" id="mount-faq-tag">{{ faq.tag }}</span>
        <h2 id="mount-faq-title">{{{ faq.title }}}</h2>
      </div>
      <div class="faq-wrap reveal" id="mount-faq-list">
        {% for item in faq.items %}
        <div class="faq-item">
          <button class="faq-q" type="button">
            <span>{{ item.q }}</span>
            <span class="faq-ic" aria-hidden="true"></span>
          </button>
          <div class="faq-a"><p>{{{ item.a }}}</p></div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="video-cta" id="video-cta">
    <img class="video-cta-bg" src="{{ videoCta.poster }}" alt="" width="1920" height="1080" loading="lazy" />
    <div class="video-cta-inner reveal">
      <h2 id="mount-video-cta-title">{{ videoCta.title }}</h2>
      <p class="video-cta-sub" id="mount-video-cta-sub">{{ videoCta.sub }}</p>
      <a class="btn btn-light" href="{{ contactPath }}" id="mount-video-cta-btn">{{ videoCta.cta }}</a>
    </div>
  </section>

{{{ @include includes/site-footer.njk }}}

{{{ @include includes/chat-fab.njk }}}

{{{ @include includes/landing-sticky.njk }}}

  <script type="module" src="/assets/interactions.js"></script>
  <script type="module" src="/assets/study-korea-locale.js"></script>
</body>
</html>
